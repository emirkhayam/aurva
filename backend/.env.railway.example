# Railway Environment Variables Configuration
# Скопируйте эти переменные в Railway Dashboard > Variables

# ============================================
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# ============================================

# Node Environment
NODE_ENV=production

# Database (Railway PostgreSQL или Neon)
# Если используете Railway PostgreSQL:
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Если используете существующий Neon PostgreSQL:
# DATABASE_URL=postgresql://neondb_owner:your_password@ep-polished-scene-aidvktov-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Configuration (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# CORS Origins (добавьте ваши домены)
CORS_ORIGIN=*

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=aurva.kg@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=aurva.kg@gmail.com

# ============================================
# ADMIN CREDENTIALS
# ============================================

ADMIN_EMAIL=admin@aurva.kg
ADMIN_PASSWORD=change_this_secure_password

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

MAX_FILE_SIZE=5242880
UPLOAD_PATH=/app/uploads

# ============================================
# RAILWAY SPECIFIC
# ============================================

# Port (Railway автоматически устанавливает)
# PORT=${{PORT}}

# ============================================
# OPTIONAL: LOGGING
# ============================================

LOG_LEVEL=info

# ============================================
# ИНСТРУКЦИИ ДЛЯ НАСТРОЙКИ
# ============================================

# 1. JWT_SECRET - сгенерируйте безопасный ключ:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 2. EMAIL_PASSWORD - создайте App Password в Google Account:
#    https://myaccount.google.com/apppasswords

# 3. DATABASE_URL - если используете Railway PostgreSQL:
#    - Добавьте PostgreSQL Plugin в Railway
#    - Используйте переменную: ${{Postgres.DATABASE_URL}}

# 4. ADMIN_PASSWORD - используйте сильный пароль:
#    - Минимум 12 символов
#    - Буквы, цифры, спецсимволы

# 5. CORS_ORIGIN - укажите ваши домены:
#    CORS_ORIGIN=https://aurva.kg,https://admin.aurva.kg
