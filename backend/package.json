{
  "name": "aurva-backend",
  "version": "1.0.0",
  "description": "Backend API для AURVA - Ассоциация Участников Рынка Виртуальных Активов",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "postinstall": "npm run build",
    "seed:admin": "ts-node src/scripts/seedAdmin.ts",
    "seed:data": "ts-node src/scripts/seedData.ts",
    "seed:news": "ts-node src/scripts/seedRealNews.ts",
    "import:aurva": "ts-node src/scripts/autoScrapeAurva.ts",
    "import:enhanced": "ts-node src/scripts/enhancedScrapeAurva.ts",
    "import:direct": "ts-node src/scripts/directFetchAurva.ts",
    "import:firecrawl": "ts-node src/scripts/firecrawlScrapeAurva.ts",
    "import:firecrawl-all": "ts-node src/scripts/firecrawlMassImport.ts",
    "import:firecrawl-hybrid": "ts-node src/scripts/hybridFirecrawlImport.ts",
    "import:firecrawl-batch": "ts-node src/scripts/firecrawlBatchImport.ts",
    "import:manual": "ts-node src/scripts/importManualNews.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "keywords": [
    "aurva",
    "crypto",
    "api",
    "express"
  ],
  "author": "AURVA",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@vercel/node": "^5.6.9",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
